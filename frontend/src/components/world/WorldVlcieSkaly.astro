---
import DynamicImage from '../shared/DynamicImage.astro'
import * as content from '../../content/pages/world.md'
import ViewTracker from '../shared/ViewTracker.astro'
import ExpandableCard from '../shared/ExpandableCard.astro'
import ParagraphWithHeader from '../shared/ParagraphWithHeader.astro'
import TextHeader from '../shared/TextHeader.astro'
import ThreeColumns from '../shared/ThreeColumns.astro'

---

<!-- Vlčie skaly -->
<ParagraphWithHeader header={content.frontmatter.vlcie_skaly_header} body={content.frontmatter.vlcie_skaly_text} />

<!-- Cechy -->
<div class='mx-auto max-w-screen-xl px-4 pt-4 sm:px-6 lg:px-8'>
</div>
  <ThreeColumns>
    <ExpandableCard
      title={content.frontmatter.cech_1_header}
      text={content.frontmatter.cech_1_body}
      image={content.frontmatter.cech_1_image}
    />
    <ExpandableCard
      title={content.frontmatter.cech_2_header}
      text={content.frontmatter.cech_2_body}
      image={content.frontmatter.cech_2_image}
    />
    <ExpandableCard
      title={content.frontmatter.cech_3_header}
      text={content.frontmatter.cech_3_body}
      image={content.frontmatter.cech_3_image}
    />
    <ExpandableCard
    title={content.frontmatter.cech_4_header}
    text={content.frontmatter.cech_4_body}
    image={content.frontmatter.cech_4_image}
    />
    <ExpandableCard
    title={content.frontmatter.cech_5_header}
    text={content.frontmatter.cech_5_body}
    image={content.frontmatter.cech_5_image}
    />
    <ExpandableCard
    title={content.frontmatter.cech_6_header}
    text={content.frontmatter.cech_6_body}
    image={content.frontmatter.cech_6_image}
    />
  </ThreeColumns>

<!-- Spolky -->
<TextHeader header={content.frontmatter.groups_header} />

<div class='mx-auto max-w-screen-xl px-4 pt-4 sm:px-6 lg:px-8'>
</div>
  <ThreeColumns>
    <ExpandableCard
      title={content.frontmatter.groups_1_header}
      text={content.frontmatter.groups_1_body}
      image={content.frontmatter.groups_1_image}
    />
    <ExpandableCard
      title={content.frontmatter.groups_2_header}
      text={content.frontmatter.groups_2_body}
      image={content.frontmatter.groups_2_image}
    />
    <ExpandableCard
      title={content.frontmatter.groups_3_header}
      text={content.frontmatter.groups_3_body}
      image={content.frontmatter.groups_3_image}
    />
    <ExpandableCard
    title={content.frontmatter.groups_4_header}
    text={content.frontmatter.groups_4_body}
    image={content.frontmatter.groups_4_image}
    />
    <ExpandableCard
    title={content.frontmatter.groups_5_header}
    text={content.frontmatter.groups_5_body}
    image={content.frontmatter.groups_5_image}
    />
    <ExpandableCard
    title={content.frontmatter.groups_6_header}
    text={content.frontmatter.groups_6_body}
    image={content.frontmatter.groups_6_image}
    />
  </ThreeColumns>

<!-- Tábor lesných bytostí -->
<ParagraphWithHeader header={content.frontmatter.tabor_header} body={content.frontmatter.tabor_body} />
<div class='relative overflow-hidden rounded-lg shadow-inner mb-8'>
  <DynamicImage src={content.frontmatter.tabor_image} class:list={'object-contain object-center shadow-inner'} />
</div>

<!-- Peklo -->
<ParagraphWithHeader header={content.frontmatter.peklo_header} body={content.frontmatter.peklo_body} />
<div class='relative overflow-hidden rounded-lg shadow-inner mb-8'>
  <DynamicImage src={content.frontmatter.peklo_image} class:list={'object-cover object-center shadow-inner'} />
</div>

<!-- Náboženstvá -->
<ParagraphWithHeader header={content.frontmatter.nabozenstva_header} body={content.frontmatter.nabozenstva_body} />

<div class='mx-auto max-w-screen-xl px-4 pt-4 sm:px-6 lg:px-8'>
</div>
  <ThreeColumns>
    <ExpandableCard
      title={content.frontmatter.nabozenstva_1_header}
      text={content.frontmatter.nabozenstva_1_body}
      image={content.frontmatter.nabozenstva_1_image}
    />
    <ExpandableCard
      title={content.frontmatter.nabozenstva_2_header}
      text={content.frontmatter.nabozenstva_2_body}
      image={content.frontmatter.nabozenstva_2_image}
    />
    <ExpandableCard
      title={content.frontmatter.nabozenstva_3_header}
      text={content.frontmatter.nabozenstva_3_body}
      image={content.frontmatter.nabozenstva_3_image}
    />
  </ThreeColumns>